{
    "info": {
      "name": "TeamFlow API",
      "description": "Complete Task Management Backend API",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
      {
        "name": "Authentication",
        "item": [
          {
            "name": "Register User",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/register",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "register"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\"\n}"
              }
            }
          },
          {
            "name": "Verify Email",
            "request": {
              "method": "GET",
              "url": {
                "raw": "{{baseUrl}}/auth/verify-email?token=TOKEN_FROM_EMAIL",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "verify-email"],
                "query": [
                  {
                    "key": "token",
                    "value": "TOKEN_FROM_EMAIL"
                  }
                ]
              }
            }
          },
          {
            "name": "Login",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/login",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "login"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
              }
            }
          },
          {
            "name": "Get Current User",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/auth/me",
                "host": ["{{baseUrl}}"],
                "path": ["auth", "me"]
              }
            }
          }
        ]
      },
      {
