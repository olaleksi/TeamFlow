              ],
              "url": {
                "raw": "{{baseUrl}}/projects/{{projectId}}",
                "host": ["{{baseUrl}}"],
                "path": ["projects", "{{projectId}}"]
              },
              "body": {
                "mode": "raw",
                "raw": "{\n    \"name\": \"Updated E-commerce Platform\",\n    \"description\": \"Updated description for the project\"\n}"
              }
            }
          },
          {
            "name": "Delete Project",
            "request": {
              "method": "DELETE",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
